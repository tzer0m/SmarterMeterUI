@page
@model IndexModel
@using SmarterMeterUI.Models
@{
    ViewData["Title"] = "Smarter Meter";

    MeterReading? latest = Model.LatestReading;

    // Last 50 readings for the sidebar
    List<MeterReading> recent = Model.Readings.TakeLast(50).Reverse().ToList();

    // Chart data
    string labels = System.Text.Json.JsonSerializer.Serialize(Model.Readings.Select(r => r.CapturedAt.ToString("yyyy-MM-ddTHH:mm:ss")));
    string values = System.Text.Json.JsonSerializer.Serialize(Model.Readings.Select(r => r.Value));
}

<div class="row g-4">

    <!-- Left panel: latest readings -->
    <div class="col-xl-1 col-lg-2 col-md-2 order-md-1 order-last">
        <div class="card h-100">
            <div class="card-header">
                <strong>Latest Readings</strong>
            </div>
            <div class="card-body p-0" style="height: calc(100vh - 160px); overflow-y: scroll; scrollbar-width: none; -ms-overflow-style: none;">
                <ul class="list-group list-group-flush">
                    @foreach (MeterReading reading in recent)
                    {
                        <li class="list-group-item">
                            <div class="fw-bold fs-5">@reading.Value.ToString("N0")</div>
                            <small class="text-muted">@reading.CapturedAt.ToLocalTime().ToString("dd MMM HH:mm")</small>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Right panel: chart + stats -->
    <div class="col-xl-11 col-lg-10 col-md-10 order-md-2 order-first">

        <!-- Stats row -->
        <div class="row g-3 mb-4">
            <div class="col-sm-4">
                <div class="card text-center">
                    <div class="card-body">
                        <div class="text-muted small">Today</div>
                        <div class="fs-4 fw-bold">@Model.Summary.TodayUsage.ToString("F0") kWh</div>
                        <div class="text-muted small">£@Model.Summary.TodayCost.ToString("F2")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card text-center">
                    <div class="card-body">
                        <div class="text-muted small">Last 7 Days</div>
                        <div class="fs-4 fw-bold">@Model.Summary.WeekUsage.ToString("F0") kWh</div>
                        <div class="text-muted small">£@Model.Summary.WeekCost.ToString("F2")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card text-center">
                    <div class="card-body">
                        <div class="text-muted small">Last 30 Days</div>
                        <div class="fs-4 fw-bold">@Model.Summary.MonthUsage.ToString("F0") kWh</div>
                        <div class="text-muted small">£@Model.Summary.MonthCost.ToString("F2")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cumulative chart -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Cumulative Usage</strong>
                <div class="btn-group btn-group-sm" id="rangeButtons" role="group">
                    <button type="button" class="btn btn-outline-secondary" onclick="filterCharts('today', this)">Today</button>
                    <button type="button" class="btn btn-outline-secondary" onclick="filterCharts('week', this)">Week</button>
                    <button type="button" class="btn btn-outline-secondary active" onclick="filterCharts('month', this)">Month</button>
                    <button type="button" class="btn btn-outline-secondary" onclick="filterCharts('year', this)">Year</button>
                </div>
            </div>
            <div class="card-body">
                <div style="position: relative; height: calc(40vh - 80px);">
                    <canvas id="cumulativeChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Consumption chart -->
        <div class="card">
            <div class="card-header">
                <strong>Consumption Per Period</strong>
            </div>
            <div class="card-body">
                <div style="position: relative; height: calc(40vh - 80px);">
                    <canvas id="consumptionChart"></canvas>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
    <script src="~/js/dashboard.js"></script>
    <script>
        var chartLabels = @Html.Raw(labels);
        var chartValues = @Html.Raw(values);
        initCharts(chartLabels, chartValues);
    </script>
}